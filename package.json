{
  "name": "territory-raider",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "description": "Territory Raider — a Volfied/Qix-style territory-capture game (web + desktop).",
  "author": "Territory Raider",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "node scripts/dev-electron.mjs",
    "build": "tsc --noEmit && vite build",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "icon": "node scripts/make-icon.mjs",
    "build:desktop": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "start:desktop": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint .",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build:desktop",
    "dist": "npm run build:desktop && electron-builder",
    "dist:dir": "npm run build:desktop && electron-builder --dir",
    "dist:mac": "npm run build:desktop && electron-builder --mac",
    "dist:win": "npm run build:desktop && electron-builder --win",
    "dist:linux": "npm run build:desktop && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
